@model List<Auth.Models.User>

@{
    ViewBag.Title = "Users";
}

<div class="container mt-5">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Идоракунии корбар</h4>
            <span class="badge bg-light text-dark">
                Total Users: @Model.Count
            </span>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Full Name</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Access</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var user in Model)
                        {
                            <tr>

                                <td>
                                    <span class="fw-bold">#@user.Id</span>
                                </td>

                                <td>
                                    <strong>@user.FullName</strong>
                                </td>

                                <td>
                                    <span class="text-muted">@user.Username</span>
                                </td>

                                <td>
                                    <span class="text-primary">@user.Email</span>
                                </td>

                                

                                    <td>

                                    @if (user.Role == "Admin")
                                    {
                                        <span class="badge bg-danger">Admin</span>
                                    }
                                    else if (user.Role == "Moderator")
                                    {
                                        <span class="badge bg-warning text-dark">Moderator</span>
                                    }
                                    else if (user.Role == "Editor")
                                    {
                                        <span class="badge bg-primary">Editor</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">User</span>
                                    }

                                    </td>

                               

                                <td>
                                    <form method="post" action="/Users/ChangeRole">

                                        <input type="hidden" name="userId" value="@user.Id" />

                                        <select name="role" class="form-select form-select-sm" onchange="this.form.submit()">

                                            <option value="User" @(user.Role == "User" ? "selected" : "")>User</option>

                                            <option value="Editor" @(user.Role == "Editor" ? "selected" : "")>Editor</option>

                                            <option value="Moderator" @(user.Role == "Moderator" ? "selected" : "")>Moderator</option>

                                            <option value="Admin" @(user.Role == "Admin" ? "selected" : "")>Admin</option>

                                        </select>

                                    </form>
                                </td>

                            </tr>
                            
                        }



                    </tbody>



                </table>

            </div>

        </div>

    </div>

</div>