@{
    ViewBag.Title = "Access Denied";
}

<div class="container mt-5">
    <div class="card shadow-lg text-center">
        <div class="card-header bg-danger text-white">
            <h3>Access Denied</h3>
        </div>
        <div class="card-body">
            <p class="lead">
                You do not have permission to access this page.
            </p>
            <p>
                Please <a href="/Account/Login">log in</a> with an account that has the required permissions.
            </p>
            <i class="bi bi-shield-lock" style="font-size: 4rem; color: #dc3545;"></i>
        </div>
        <div class="card-footer text-muted">
            If you believe this is a mistake, contact the administrator.
        </div>
    </div>
</div>