@model List<Auth.Models.Post>

@{
    ViewBag.Title = "Dashboard";
}



<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Posts</h2>

        <a href="/Posts/Create" class="btn btn-primary">
            + Create Post
        </a>
    </div>

    @foreach (var post in Model)
    {

        <div class="card shadow-sm mb-4">

            <div class="card-body">

                <h4>@post.Title</h4>

                <p class="text-muted">
                    by <b>@post.Author</b>
                    | @post.CreatedAt.ToString("dd MMM yyyy HH:mm")
                </p>

                <p>
                    @post.Content
                </p>
                @if (Session["Role"] != null)
                {
                    var role = Session["Role"].ToString();

                    if (role == "Admin" || role == "Editor" || role == "Moderator" || Session["Username"].ToString() == post.Author)
                    {
                        <a href="/Posts/Edit/@post.Id" class="btn btn-warning btn-sm mt-2">
                            Edit
                        </a>
                    }
                }

                @if (Session["Role"] != null)
                {
                    var role = Session["Role"].ToString();

                    if (role == "Moderator" || role == "Admin")
                    {
                        <a href="/Posts/Delete/@post.Id" class="btn btn-danger btn-sm mt-2 ms-2">
                            Delete
                        </a>
                    }
                }
            </div>

        </div>

    }

</div>