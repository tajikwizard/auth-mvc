@model List<Auth.Models.Post>

@{
    ViewBag.Title = "Dashboard";
}

<style>
    /* Container */
    .dashboard-container {
        max-width: 1000px;
        margin: auto;
    }

    /* Card styling */
    .card-modern {
        border: none;
        border-radius: 12px;
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
        transition: transform 0.2s, box-shadow 0.2s;
        background: #f4f8fc;
    }

        .card-modern:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }

        /* Card title */
        .card-modern h4 {
            font-weight: 600;
            color: #1e3c72;
        }

        /* Metadata */
        .card-modern .meta-info {
            font-size: 0.875rem;
            color: #6c757d;
        }

    /* Buttons */
    .btn-modern {
        border-radius: 8px;
        font-weight: 500;
        padding: 0.375rem 0.75rem;
        transition: all 0.2s;
    }

    .btn-modern-primary {
        background: #1e3c72;
        color: #fff;
        border: none;
    }

        .btn-modern-primary:hover {
            background: #2a5298;
            color: #fff;
        }

    .btn-modern-warning {
        background: #ffc107;
        color: #1e1e1e;
        border: none;
    }

        .btn-modern-warning:hover {
            background: #e0b507;
            color: #1e1e1e;
        }

    .btn-modern-danger {
        background: #dc3545;
        color: #fff;
        border: none;
    }

        .btn-modern-danger:hover {
            background: #b02a37;
            color: #fff;
        }

    /* Create Post Button */
    .create-post-btn {
        border-radius: 12px;
        font-weight: 600;
        background: linear-gradient(90deg, #1e3c72, #2a5298);
        color: #fff;
        border: none;
        transition: all 0.2s;
    }

        .create-post-btn:hover {
            background: linear-gradient(90deg, #2a5298, #1e3c72);
            color: #fff;
        }

    /* Spacing */
    .card-body p {
        margin-bottom: 0.5rem;
    }
</style>

<div class="dashboard-container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
        <h2 class="mb-2 mb-md-0">Posts</h2>
        <a href="/Posts/Create" class="btn create-post-btn">
            + Create Post
        </a>
    </div>

    @foreach (var post in Model)
    {
        <div class="card card-modern mb-4">
            <div class="card-body">
                <h4>@post.Title</h4>

                <p class="meta-info mb-2">
                    by <b>@post.Author</b>
                    | @post.CreatedAt.ToString("dd MMM yyyy HH:mm")
                </p>

                <p>@post.Content</p>

                <div class="mt-3">
                    @if (Session["Role"] != null)
                    {
                        var role = Session["Role"].ToString();

                        if (role == "Admin" || role == "Editor" || role == "Moderator" || Session["Username"].ToString() == post.Author)
                        {
                            <a href="/Posts/Edit/@post.Id" class="btn btn-modern btn-modern-warning btn-sm me-2">
                                Edit
                            </a>
                        }
                    }

                    @if (Session["Role"] != null)
                    {
                        var role = Session["Role"].ToString();

                        if (role == "Moderator" || role == "Admin")
                        {
                            <a href="/Posts/Delete/@post.Id" class="btn btn-modern btn-modern-danger btn-sm">
                                Delete
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>