@model List<Auth.Models.Post>

@{
    ViewBag.Title = "Dashboard";
}



<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Posts</h2>

        <a href="/Posts/Create" class="btn btn-primary">
            + Create Post
        </a>
    </div>

    @foreach (var post in Model)
    {

        <div class="card shadow-sm mb-4">

            <div class="card-body">

                <h4>@post.Title</h4>

                <p class="text-muted">
                    by <b>@post.Author</b> |
                    @post.CreatedAt.ToString("dd MMM yyyy HH:mm")
                </p>

                <p>
                    @post.Content
                </p>
                @if (Session["Username"] != null &&
                    (Session["Username"].ToString() == post.Author || Session["Role"].ToString() == "Admin"))
                {
                    <a href="/Posts/Edit/@post.Id" class="btn btn-warning btn-sm mt-2">Edit</a>
                }
            </div>

        </div>

    }

</div>