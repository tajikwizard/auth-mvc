@{
    ViewBag.Title = "Register";
}
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>

    body {
        background: #f5f7fb;
    }

    .auth-container {
        height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-card {
        width: 900px;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        background: white;
    }

    .auth-left {
        background: linear-gradient(135deg,#4f46e5,#3b82f6);
        color: white;
        padding: 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .auth-left h2 {
            font-weight: 700;
            margin-bottom: 15px;
        }

    .auth-right {
        padding: 40px;
    }

    .form-control {
        border-radius: 8px;
        padding: 12px;
    }

    .btn-register {
        background: #4f46e5;
        border: none;
        padding: 12px;
        border-radius: 8px;
        font-weight: 600;
    }

        .btn-register:hover {
            background: #4338ca;
        }
</style>


<div class="container auth-container">

    <div class="row auth-card">

        <!-- LEFT SIDE -->
        <div class="col-md-5 auth-left">

            <h2>Хуш омадед 👋</h2>

            <p>
                Барои дастрасӣ ба платформа акканути худро эҷод кунед ва ба омӯхтан шурӯъ кунед
                тамоми хусусиятҳои дастрас.
            </p>

        </div>

        <!-- RIGHT SIDE -->
        <div class="col-md-7 auth-right">

            <h3 class="mb-4">Create Account</h3>

            <form method="post">

                <div class="mb-3">
                    <label>Full Name</label>
                    <input type="text" name="FullName" class="form-control" placeholder="Abdusamadzoda Abdulaziz" required />
                </div>

                <div class="mb-3">
                    <label>Username</label>
                    <input type="text" name="Username" class="form-control" placeholder="abdulaziz" required />
                </div>

                <div class="mb-3">
                    <label>Email</label>
                    <input type="email" name="Email" class="form-control" placeholder="abdulaziz@email.com" required />
                </div>

                <div class="mb-4">
                    <label>Password</label>
                    <input type="password" name="Password" class="form-control" placeholder="Enter password" required />
                </div>

                <button type="submit" class="btn btn-register w-100 text-white">
                    Create Account
                </button>

            </form>

            <p class="mt-3 text-center">
                Already have an account?
                <a href="/Account/Login">Login</a>
            </p>

        </div>

    </div>

</div>