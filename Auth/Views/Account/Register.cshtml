@model Auth.Models.User

@{
    ViewBag.Title = "Register";
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger container mt-3">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>

body{
    background:#f5f7fb;
}

.auth-container{
 
    min-height:calc(100vh - 140px);
    display:flex;
    align-items:center;
    justify-content:center;
    padding:20px 15px;
}

.auth-card{
    max-width:900px;
    width:100%;
    border-radius:14px;
    overflow:hidden;
    box-shadow:0 15px 40px rgba(0,0,0,0.08);
    background:white;
}

.auth-left{
    background:linear-gradient(135deg,#4f46e5,#3b82f6);
    color:white;
    padding:50px 40px;
    display:flex;
    flex-direction:column;
    justify-content:center;
}

.auth-left h2{
    font-weight:700;
    margin-bottom:15px;
}

.auth-right{
    padding:45px 40px;
}

.form-control{
    border-radius:8px;
    padding:12px;
}

.btn-register{
    background:#4f46e5;
    border:none;
    padding:12px;
    border-radius:8px;
    font-weight:600;
    transition:0.2s;
}

.btn-register:hover{
    background:#4338ca;
}


</style>


<div class="container auth-container">

    <div class="row auth-card g-0">

        <!-- LEFT PANEL -->
        <div class="col-md-5 auth-left">

            <h2>Хуш омадед 👋</h2>

            <p>
                Барои дастрасӣ ба платформа акканути худро эҷод кунед ва ба омӯхтан шурӯъ кунед
                тамоми хусусиятҳои дастрас.
            </p>

        </div>

        <!-- RIGHT PANEL -->
        <div class="col-md-7 auth-right">

            <h3 class="mb-4">Ҳисоб кушоед</h3>

            @using (Html.BeginForm("Register", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label>Ном ва Насаб</label>
                    @Html.TextBoxFor(m => m.FullName, new { @class = "form-control", placeholder = "Номи худро ворид намоед" })
                </div>

                <div class="mb-3 w-100">
                    <label>Почта</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email", placeholder = "Почта" })
                </div>

                <div class="mb-3">
                    <label>Рамз</label>
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Рамзи худро ворид намоед" })
                </div>

                <button type="submit" class="btn btn-register w-100 text-white">
                    Ҳисоб кушодан
                </button>
            }

            <p class="mt-3 text-center">
                Алакай хисоб доред?
                <a href="/Account/Login">Даромадан</a>
            </p>

        </div>

    </div>

</div>