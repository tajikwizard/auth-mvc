@{
    ViewBag.Title = "Change Password";
}

<style>
    .change-password-container {
        max-width: 350px;
        margin: 40px auto;
        padding: 30px;
        border-radius: 12px;
        background: #f4f8fc;
        box-shadow: 0 6px 18px rgba(0,0,0,0.1);
    }

    .form-header {
        font-size: 1.6rem;
        font-weight: 600;
        color: #1e3c72;
        margin-bottom: 20px;
        border-bottom: 2px solid #2a5298;
        padding-bottom: 8px;
    }

    label {
        font-weight: 500;
        margin-bottom: 5px;
        display: block;
        color: #2a2a2a;
    }

    input[type=password] {
        width: 100%;
        border-radius: 8px;
        border: 1px solid #ced4da;
        padding: 0.5rem 0.75rem;
        margin-bottom: 15px;
        transition: all 0.2s;
    }

        input[type=password]:focus {
            outline: none;
            border-color: #2a5298;
            box-shadow: 0 0 5px rgba(42,82,152,0.4);
        }

    .btn-modern {
        border-radius: 10px;
        padding: 0.5rem 1rem;
        font-weight: 500;
        transition: all 0.2s;
    }

    .btn-modern-success {
        background: linear-gradient(90deg, #28a745, #1e7e34);
        color: #fff;
        border: none;
    }

        .btn-modern-success:hover {
            background: linear-gradient(90deg, #1e7e34, #28a745);
            color: #fff;
        }

    .text-success-message {
        color: #28a745;
        font-weight: 500;
        margin-bottom: 15px;
    }

    .text-error-message {
        color: #dc3545;
        font-weight: 500;
        margin-bottom: 15px;
    }
</style>

<div class="change-password-container">
    <div class="form-header">Change Password</div>

    @if (ViewBag.SuccessMessage != null)
    {
        <div class="text-success-message">@ViewBag.SuccessMessage</div>
    }

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="text-error-message">@ViewBag.ErrorMessage</div>
    }

    <form method="post" action="/Account/ChangePassword">
        <label>Current Password</label>
        <input type="password" name="CurrentPassword" required />

        <label>New Password</label>
        <input type="password" name="NewPassword" required />
        <br/>
        <button type="submit" class="btn btn-modern btn-modern-success">Save Changes</button>
    </form>
</div>